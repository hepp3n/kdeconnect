{
    "id": "io.github.hepp3n.kdeconnect",
    "runtime": "org.freedesktop.Platform",
    "runtime-version": "25.08",
    "base": "com.system76.Cosmic.BaseApp",
    "base-version": "stable",
    "sdk": "org.freedesktop.Sdk",
    "sdk-extensions": [
        "org.freedesktop.Sdk.Extension.rust-stable"
    ],
    "command": "cosmic-ext-connect-applet",
    "finish-args": [
        "--share=ipc",
        "--socket=wayland",
        "--socket=inherit-wayland-socket",
        "--socket=session-bus",
        "--device=dri",
        "--share=network",
        "--filesystem=home:ro",
        "--filesystem=xdg-download",
        "--filesystem=xdg-config/systemd",
        "--filesystem=xdg-config/cosmic:rw",
        "--talk-name=org.freedesktop.Notifications",
        "--talk-name=org.freedesktop.portal.Desktop"
    ],
    "build-options": {
        "append-path": "/usr/lib/sdk/rust-stable/bin"
    },
    "modules": [
        {
            "name": "cosmic-ext-connect-applet",
            "buildsystem": "simple",
            "build-options": {
                "env": {
                    "CARGO_HOME": "/run/build/cosmic-ext-connect-applet/cargo"
                }
            },
            "build-commands": [
                "just PREFIX=/app install"
            ],
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/hepp3n/kdeconnect",
                    "branch": "master"
                },
                "cargo-sources.json"
            ]
        }
    ]
}
